{
  "name": "@dyst-no/worker",
  "version": "0.1.1",
  "description": "TypeScript helpers for cron and event-driven background workers.",
  "keywords": [
    "worker",
    "cron",
    "scheduler",
    "postgres",
    "typescript"
  ],
  "homepage": "https://github.com/dyst-no/worker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyst-no/worker.git"
  },
  "bugs": {
    "url": "https://github.com/dyst-no/worker/issues"
  },
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "format": "biome check --write --error-on-warnings .",
    "typecheck": "tsgo --noEmit",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "prepublishOnly": "bun run build && bun run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/bun": "latest",
    "@types/node-cron": "^3.0.11",
    "@typescript/native-preview": "^7.0.0-dev.20260318.1",
    "node-cron": "^3.0.3",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.2",
    "postgres": "^3.4.5",
    "tsdown": "^0.21.4"
  },
  "peerDependencies": {
    "node-cron": "^3.0.3",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.2",
    "postgres": "^3.4.5"
  }
}
